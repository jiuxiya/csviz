    "data-visualization",
    "no-dependencies",
    "watch",
    "filter",
    "export",
    "json",
    "yaml",
    "cli-tool",
    "data-analysis"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
